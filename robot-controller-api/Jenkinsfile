pipeline {
    agent any

    options {
        timestamps()
        disableConcurrentBuilds()
    }

    environment {
        PROJECT_NAME   = 'robot-controller-api'
        SOLUTION_FILE  = 'robot-controller-api.sln'
        PROJECT_FILE   = 'robot-controller-api.csproj'
        BUILD_CONFIG   = 'Release'

        IMAGE_NAME     = 'robot-api'
        IMAGE_TAG      = "${BUILD_NUMBER}"
        FULL_IMAGE     = "${IMAGE_NAME}:${IMAGE_TAG}"

        CONTAINER_NAME = 'robot-api-container'
        HOST_PORT      = '8081'
        CONTAINER_PORT = '8080'

        TRIVY_EXE      = 'C:\\Users\\user\\AppData\\Local\\Microsoft\\WinGet\\Links\\trivy.exe'
        DOCKER_EXE     = 'C:\\Program Files\\Docker\\Docker\\resources\\bin\\docker.exe'

        SONARQUBE_ENV      = 'SonarQubeServer'
        SONAR_PROJECT_KEY  = 'robot-controller-api'
        SONAR_PROJECT_NAME = 'robot-controller-api'
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
                bat 'echo Source code checked out successfully.'
            }
        }

        stage('Build') {
            steps {
                bat "dotnet restore %SOLUTION_FILE%"
                bat "dotnet build %SOLUTION_FILE% --configuration %BUILD_CONFIG% --no-restore"
                bat "dotnet publish %PROJECT_FILE% -c %BUILD_CONFIG% -o publish"
            }
            post {
                success {
                    archiveArtifacts artifacts: 'publish/**', fingerprint: true
                }
            }
        }

        stage('Test') {
            steps {
                bat 'if exist TestResults rmdir /s /q TestResults'
                bat 'mkdir TestResults'
                bat "dotnet test %SOLUTION_FILE% --configuration %BUILD_CONFIG% --no-build --logger \"trx;LogFileName=test_results.trx\" --results-directory TestResults"
            }
            post {
                always {
                    archiveArtifacts artifacts: 'TestResults/**/*.trx', allowEmptyArchive: true
                }
            }
        }

        stage('Code Quality') {
            steps {
                withSonarQubeEnv("${SONARQUBE_ENV}") {
                    bat """
                    dotnet sonarscanner begin /k:"%SONAR_PROJECT_KEY%" /n:"%SONAR_PROJECT_NAME%" /d:sonar.host.url=%SONAR_HOST_URL% /d:sonar.token=%SONAR_AUTH_TOKEN%
                    dotnet build %SOLUTION_FILE% --configuration %BUILD_CONFIG%
                    dotnet sonarscanner end /d:sonar.token=%SONAR_AUTH_TOKEN%
                    """
                }
            }
        }

        stage('Security') {
            steps {
                bat "\"%TRIVY_EXE%\" fs --severity HIGH,CRITICAL --format table --output trivy-filesystem-report.txt ."
                bat "\"%DOCKER_EXE%\" build -t %FULL_IMAGE% ."
                bat "\"%TRIVY_EXE%\" image --severity HIGH,CRITICAL --format table --output trivy-image-report.txt %FULL_IMAGE%"
            }
            post {
                always {
                    archiveArtifacts artifacts: 'trivy-filesystem-report.txt, trivy-image-report.txt', allowEmptyArchive: true
                }
            }
        }

        stage('Deploy') {
            steps {
                bat "\"%DOCKER_EXE%\" rm -f %CONTAINER_NAME% || exit /b 0"
                bat "\"%DOCKER_EXE%\" run -d -p %HOST_PORT%:%CONTAINER_PORT% --name %CONTAINER_NAME% %FULL_IMAGE%"
            }
        }

        stage('Release') {
            steps {
                bat "\"%DOCKER_EXE%\" tag %FULL_IMAGE% %IMAGE_NAME%:latest"
                bat "echo Release created: %IMAGE_NAME%:latest"
            }
        }

        stage('Monitoring') {
            steps {
                powershell '''
                    Start-Sleep -Seconds 10
                    $url = "http://localhost:$env:HOST_PORT/health"
                    Write-Host "Checking application health at $url"
                    try {
                        $response = Invoke-WebRequest -Uri $url -UseBasicParsing
                        Write-Host "Status Code: $($response.StatusCode)"
                        Write-Host "Response: $($response.Content)"
                        if ($response.StatusCode -ne 200) {
                            throw "Health endpoint returned non-200 status."
                        }
                    }
                    catch {
                        Write-Error "Monitoring failed: $($_.Exception.Message)"
                        exit 1
                    }
                '''
            }
        }
    }

    post {
        success {
            echo 'All 7 pipeline stages completed successfully.'
        }
        failure {
            echo 'Pipeline failed. Check the console output and reports.'
        }
        always {
            bat "\"%DOCKER_EXE%\" ps -a || exit /b 0"
        }
    }
}